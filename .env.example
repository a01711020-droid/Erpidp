# ============================================================
# ERP IDP — Variables de entorno
# Copia este archivo como .env.local para desarrollo
# NUNCA subas .env.local al repositorio
# ============================================================

# ----------------------------------------------------------
# MODO DE DATOS
# ----------------------------------------------------------

# true  = usa datos mock en memoria (no necesitas backend)
# false = conecta al backend real (requiere VITE_API_BASE_URL)
VITE_MOCK_MODE=true

# Solo para testing: muestra pantallas vacías (empty state)
VITE_TEST_EMPTY_STATE=false

# Simula delay de red en el mock (hace más realista el UX)
VITE_SIMULATE_DELAY=true

# ----------------------------------------------------------
# BACKEND API
# ----------------------------------------------------------

# URL base del backend FastAPI
# Desarrollo local:
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Producción Azure (ejemplo):
# VITE_API_BASE_URL=https://erp-idp-api.azurewebsites.net/api/v1

# Timeout de requests en milisegundos
VITE_API_TIMEOUT=30000

# ----------------------------------------------------------
# DEBUGGING
# ----------------------------------------------------------

# Loggear todas las llamadas al adapter en consola
VITE_LOG_ADAPTER=false
